<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Claude CLI Chat"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Native Android interface for Claude CLI"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="28dp" />

        <!-- Termux status -->
        <TextView
            android:id="@+id/termux_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- Setup instructions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETUP — first time only"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#D4A843"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- Step 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#D4A843"
                android:gravity="center"
                android:layout_marginRight="12dp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Install Termux"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Download from F-Droid or GitHub. Do NOT use the Play Store version — it is outdated."
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>
        </LinearLayout>

        <!-- Step 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#D4A843"
                android:gravity="center"
                android:layout_marginRight="12dp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Install Node.js + Claude CLI in Termux"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open Termux and run:"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="pkg install nodejs\nnpm install -g @anthropic-ai/claude-code"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#D4A843"
                    android:background="#1A1A1A"
                    android:padding="8dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Step 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="3"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#D4A843"
                android:gravity="center"
                android:layout_marginRight="12dp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Install Python in Termux"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="pkg install python"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textColor="#D4A843"
                    android:background="#1A1A1A"
                    android:padding="8dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Step 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="4"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#D4A843"
                android:gravity="center"
                android:layout_marginRight="12dp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get your Anthropic API key"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Go to console.anthropic.com → Settings → API Keys → Create Key"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>
        </LinearLayout>

        <!-- Step 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="5"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="#D4A843"
                android:gravity="center"
                android:layout_marginRight="12dp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allow Termux RUN_COMMAND permission"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="In Termux: Settings → Allow External Apps (or run: settings put global termux_allow_external_apps true)"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="24dp" />

        <!-- API Key input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anthropic API Key"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/api_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="sk-ant-..."
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/install_bridge_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Step 6 — Install Bridge Script"
            android:backgroundTint="#1E1E1E"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/launch_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Launch Claude"
            android:backgroundTint="#D4A843"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
