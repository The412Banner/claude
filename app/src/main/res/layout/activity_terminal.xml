<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <ScrollView
        android:id="@+id/terminal_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/terminal_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="#E0E0E0"
            android:lineSpacingMultiplier="1.3"
            android:text="" />

    </ScrollView>

    <!-- Extra keys row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button android:id="@+id/key_esc"
            style="@style/ExtraKey"
            android:text="ESC" />
        <Button android:id="@+id/key_tab"
            style="@style/ExtraKey"
            android:text="TAB" />
        <Button android:id="@+id/key_up"
            style="@style/ExtraKey"
            android:text="▲" />
        <Button android:id="@+id/key_down"
            style="@style/ExtraKey"
            android:text="▼" />
        <Button android:id="@+id/key_left"
            style="@style/ExtraKey"
            android:text="◀" />
        <Button android:id="@+id/key_right"
            style="@style/ExtraKey"
            android:text="▶" />
        <Button android:id="@+id/key_enter"
            style="@style/ExtraKey"
            android:layout_weight="2"
            android:text="ENTER" />

    </LinearLayout>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:padding="8dp">

        <EditText
            android:id="@+id/terminal_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="@null"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="4"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/send_btn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="#D4A843"
            android:padding="10dp"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

</LinearLayout>
